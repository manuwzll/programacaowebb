@model Biblioteca.Models.EditarLivroViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Livro";
}

<div class="container py-5">
    <div style="max-width: 600px; margin: 0 auto; background: #fdfaf5; padding: 40px; border-radius: 15px; border: 1px solid #d4c3a3;">
        <h2 style="font-family: 'Cinzel', serif; color: #4b3621; text-align: center; margin-bottom: 30px;">EDITAR LIVRO</h2>

        <form asp-action="EditarLivro" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label" style="font-weight:bold; color:#4b3621;">Título</label>
                <input asp-for="Titulo" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label" style="font-weight:bold; color:#4b3621;">Autor</label>
                <select asp-for="AutorId" asp-items="@ViewBag.Autores" class="form-control" required></select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" style="font-weight:bold; color:#4b3621;">Gênero</label>
                    <input asp-for="Genero" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label" style="font-weight:bold; color:#4b3621;">Páginas</label>
                    <input asp-for="NumPag" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label" style="font-weight:bold; color:#4b3621;">Data de Publicação</label>
                <input asp-for="DataPublicacao" type="date" class="form-control" required />
            </div>

            <div class="text-center">
                <a asp-action="Livro" asp-route-id="@Model.Id" class="btn btn-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-dark" style="background:#4b3621; border:none;">Salvar Alterações</button>
            </div>
        </form>
    </div>
</div>