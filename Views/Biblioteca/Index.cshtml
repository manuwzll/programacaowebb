            <div class="book-grid">
                <div class="book-card" data-search="senhor dos aneis j. r. r. tolkien">
                    <a asp-action="Livro" asp-route-id="1"><img src="~/img/ANEL.JPG"></a>
                    <h6>SENHOR DOS ANÉIS</h6>
                    <a asp-action="Livro" asp-route-id="1" class="btn-saiba">VER OBRA</a>
                </div>
                <div class="book-card" data-search="harry potter j.k. rowling">
                    <a asp-action="Livro" asp-route-id="2"><img src="~/img/potter.jpg"></a>
                    <h6>HARRY POTTER</h6>
                    <a asp-action="Livro" asp-route-id="2" class="btn-saiba">VER OBRA</a>
                </div>
                <div class="book-card" data-search="rainha vermelha victoria aveyard">
                    <a asp-action="Livro" asp-route-id="3"><img src="~/img/rainha.jpg"></a>
                    <h6>RAINHA VERMELHA</h6>
                    <a asp-action="Livro" asp-route-id="3" class="btn-saiba">VER OBRA</a>
                </div>
                <div class="book-card" data-search="percy jackson rick riordan">
                    <a asp-action="Livro" asp-route-id="4"><img src="~/img/percy.jpg"></a>
                    <h6>PERCY JACKSON</h6>
                    <a asp-action="Livro" asp-route-id="4" class="btn-saiba">VER OBRA</a>
                </div>
            </div>
        </div>

        <div id="section-gostar">
            <h4 class="section-title">Você Pode Gostar</h4>
            <div class="book-grid">
                <div class="book-card" data-search="as cronicas de narnia c. s. lewis">
                    <a asp-action="Livro" asp-route-id="5"><img src="~/img/narnia.jpg"></a>
                    <h6>AS CRÔNICAS DE NÁRNIA</h6>
                    <a asp-action="Livro" asp-route-id="5" class="btn-saiba">DESCUBRA</a>
                </div>
                <div class="book-card" data-search="eragon christopher paolini">
                    <a asp-action="Livro" asp-route-id="6"><img src="~/img/eragon.jpg"></a>
                    <h6>ERAGON</h6>
                    <a asp-action="Livro" asp-route-id="6" class="btn-saiba">DESCUBRA</a>
                </div>
                <div class="book-card" data-search="a bussola de ouro philip pullman">
                    <a asp-action="Livro" asp-route-id="7"><img src="~/img/bussola.jpg"></a>
                    <h6>A BÚSSOLA DE OURO</h6>
                    <a asp-action="Livro" asp-route-id="7" class="btn-saiba">DESCUBRA</a>
                </div>
                <div class="book-card" data-search="o nome do vento patrick rothfuss">
                    <a asp-action="Livro" asp-route-id="8"><img src="~/img/nomedovento.jpg"></a>
                    <h6>O NOME DO VENTO</h6>
                    <a asp-action="Livro" asp-route-id="8" class="btn-saiba">DESCUBRA</a>
                </div>
            </div>
        </div>

        <button class="btn-acesso-total" onclick="mostrarCatalogo()" id="btnCatalogo">ACESSE O CATÁLOGO</button>

        <div id="catalogo-completo">
            <h4 class="section-title">Catálogo Completo</h4>
            <div class="book-grid">
                <div class="book-card" data-search="senhor dos aneis tolkien"><a asp-action="Livro" asp-route-id="1"><img src="~/img/ANEL.JPG"></a><h6>SENHOR DOS ANÉIS</h6></div>
                <div class="book-card" data-search="harry potter rowling"><a asp-action="Livro" asp-route-id="2"><img src="~/img/potter.jpg"></a><h6>HARRY POTTER</h6></div>
                <div class="book-card" data-search="rainha vermelha aveyard"><a asp-action="Livro" asp-route-id="3"><img src="~/img/rainha.jpg"></a><h6>RAINHA VERMELHA</h6></div>
                <div class="book-card" data-search="percy jackson riordan"><a asp-action="Livro" asp-route-id="4"><img src="~/img/percy.jpg"></a><h6>PERCY JACKSON</h6></div>
                <div class="book-card" data-search="narnia lewis"><a asp-action="Livro" asp-route-id="5"><img src="~/img/narnia.jpg"></a><h6>AS CRÔNICAS DE NÁRNIA</h6></div>
                <div class="book-card" data-search="eragon paolini"><a asp-action="Livro" asp-route-id="6"><img src="~/img/eragon.jpg"></a><h6>ERAGON</h6></div>
                <div class="book-card" data-search="bussola ouro pullman"><a asp-action="Livro" asp-route-id="7"><img src="~/img/bussola.jpg"></a><h6>A BÚSSOLA DE OURO</h6></div>
                <div class="book-card" data-search="nome do vento rothfuss"><a asp-action="Livro" asp-route-id="8"><img src="~/img/nomedovento.jpg"></a><h6>O NOME DO VENTO</h6></div>
                <div class="book-card" data-search="mago terramar ursula le guin"><a asp-action="Livro" asp-route-id="9"><img src="~/img/terramar.jpg"></a><h6>O MAGO DE TERRAMAR</h6></div>
                <div class="book-card" data-search="cidade dos ossos cassandra clare"><a asp-action="Livro" asp-route-id="10"><img src="~/img/cidadeossos.jpg"></a><h6>CIDADE DOS OSSOS</h6></div>
                <div class="book-card" data-search="alquimista nicolas flamel michael scott"><a asp-action="Livro" asp-route-id="11"><img src="~/img/alquimista.jpg"></a><h6>O ALQUIMISTA (FLAMEL)</h6></div>
                <div class="book-card" data-search="neverwhere neil gaiman"><a asp-action="Livro" asp-route-id="12"><img src="~/img/neverwhere.jpg"></a><h6>NEVERWHERE</h6></div>
                <div class="book-card" data-search="piramide vermelha rick riordan"><a asp-action="Livro" asp-route-id="13"><img src="~/img/piramide.jpg"></a><h6>A PIRÂMIDE VERMELHA</h6></div>
            </div>
        </div>
    </div>
</div>

<script>
    function mostrarCatalogo() {
        var x = document.getElementById("catalogo-completo");
        var btn = document.getElementById("btnCatalogo");
        if (x.style.display === "none" || x.style.display === "") {
            x.style.display = "block";
            btn.innerHTML = "FECHAR CATÁLOGO";
        } else {
            x.style.display = "none";
            btn.innerHTML = "ACESSE O CATÁLOGO";
        }
    }

    function filtrarLivros() {
        var input = document.getElementById("inputBusca").value.toLowerCase();
        var principal = document.getElementById("conteudo-principal");
        var sobreNos = document.getElementById("section-sobre");
        var containerResultados = document.getElementById("container-resultados");
        var feedback = document.getElementById("search-fallback");
        
        // Pegamos todos os cards que existem no catálogo completo (que tem todos)
        var todosOsCards = document.querySelectorAll("#catalogo-completo .book-card");
        var gridResultados = document.getElementById("grid-resultados");

        // Limpa o grid de resultados antes de filtrar
        gridResultados.innerHTML = "";

        if (input.trim() === "") {
            // Se a busca estiver vazia, volta ao normal
            principal.classList.remove("item-hidden");
            sobreNos.classList.remove("item-hidden");
            containerResultados.classList.add("item-hidden");
            feedback.style.display = "none";
            return;
        }

        // Se estiver pesquisando:
        principal.classList.add("item-hidden");
        sobreNos.classList.add("item-hidden");
        
        var encontrou = false;

        todosOsCards.forEach(function(card) {
            var searchData = card.getAttribute("data-search").toLowerCase();
            if (searchData.indexOf(input) > -1) {
                // Clona o card para exibir na seção de resultados
                var clone = card.cloneNode(true);
                clone.classList.remove("item-hidden");
                gridResultados.appendChild(clone);
                encontrou = true;
            }
        });

        if (encontrou) {
            containerResultados.classList.remove("item-hidden");
            feedback.style.display = "none";
        } else {
            containerResultados.classList.add("item-hidden");
            feedback.style.display = "block";
        }
    }
</script>