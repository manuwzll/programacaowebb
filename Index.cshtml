@{ Layout = "_Layout"; }
<style>
    .hero-banner {
        background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66');
        background-size: cover; background-position: center;
        height: 350px; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; text-align: center;
    }
    .hero-banner h1 { font-family: 'Cinzel', serif; font-size: 2.2rem; letter-spacing: 4px; }
    .book-grid { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; padding: 50px 0; }
    .book-card { width: 190px; text-align: center; }
    .book-card img { width: 100%; height: 280px; object-fit: cover; border-radius: 5px; box-shadow: 0 10px 20px rgba(0,0,0,0.2); cursor: pointer; }
    .book-card h6 { font-family: 'Cinzel', serif; margin-top: 15px; font-weight: bold; }
    .btn-saiba { font-size: 0.7rem; font-weight: bold; color: #4b3621; text-decoration: underline; cursor: pointer; }
</style>

<section class="hero-banner text-uppercase">
    <h1>Onde cada página é um novo horizonte</h1>
    <p style="color: #c4a484; letter-spacing: 2px;">Sua jornada começa aqui</p>
</section>

<div class="container text-center mt-5">
    <h4 style="font-family: 'Cinzel', serif; font-weight: bold;">SOBRE NÓS:</h4>
    <p class="mx-auto" style="max-width: 700px;">O Lounge Literário não é apenas um repositório de livros; é um refúgio para mentes curiosas. Nascemos da paixão pelas histórias que moldam gerações.</p>
    
    <h4 style="font-family: 'Cinzel', serif; font-weight: bold; margin-top: 60px;">DESTAQUES DA SEMANA:</h4>
    <div class="book-grid">
        <div class="book-card">
            <a asp-action="Livro" asp-route-id="1"><img src="~/img/ANEL.JPG"></a>
            <h6>SENHOR DOS ANÉIS</h6>
            <a asp-action="Livro" asp-route-id="1" class="btn-saiba">SAIBA MAIS</a>
        </div>
        <div class="book-card">
            <a asp-action="Livro" asp-route-id="2"><img src="~/img/potter.jpg"></a>
            <h6>HARRY POTTER</h6>
            <a asp-action="Livro" asp-route-id="2" class="btn-saiba">SAIBA MAIS</a>
        </div>
        <div class="book-card">
            <a asp-action="Livro" asp-route-id="3"><img src="~/img/rainha.jpg"></a>
            <h6>RAINHA VERMELHA</h6>
            <a asp-action="Livro" asp-route-id="3" class="btn-saiba">SAIBA MAIS</a>
        </div>
        <div class="book-card">
            <a asp-action="Livro" asp-route-id="4"><img src="~/img/percy.jpg"></a>
            <h6>Percy Jackson-O ladrão de raios</h6>
            <a asp-action="Livro" asp-route-id="4" class="btn-saiba">SAIBA MAIS</a>
            
        </div>
    </div>
</div>